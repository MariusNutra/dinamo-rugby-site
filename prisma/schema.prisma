generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            Int                       @id @default(autoincrement())
  username      String                    @unique
  password      String
  name          String
  email         String?
  role          String                    @default("editor")
  active        Boolean                   @default(true)
  roleId        Int?
  teamIds       String?
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt
  conversations ConversationParticipant[]
  sentMessages  Message[]
  roleRef       Role?                     @relation(fields: [roleId], references: [id])
}

model Story {
  id         Int      @id @default(autoincrement())
  title      String
  slug       String   @unique
  content    String
  excerpt    String?
  coverImage String?
  videoUrl   String?
  grupa      String?
  category   String?
  status     String   @default("published")
  published  Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  photos     Photo[]
}

model Photo {
  id        Int      @id @default(autoincrement())
  filename  String
  path      String
  caption   String?
  grupa     String?
  albumName String?
  storyId   Int?
  createdAt DateTime @default(now())
  story     Story?   @relation(fields: [storyId], references: [id])
}

model Team {
  id                 Int                 @id @default(autoincrement())
  grupa              String              @unique
  coachName          String
  coachPhoto         String?
  coachBio           String?
  schedule           String?
  description        String?
  active             Boolean             @default(true)
  color              String              @default("green")
  sortOrder          Int                 @default(0)
  ageRange           String?
  birthYear          String?
  updatedAt          DateTime            @updatedAt
  accessRequests     AccessRequest[]
  attendances        Attendance[]
  attendanceSessions AttendanceSession[]
  calendarEvents     CalendarEvent[]
  children           Child[]
  coaches            Coach[]
  conversations      Conversation[]
  documents          Document[]
  registrations      Registration[]
  tacticalBoards     TacticalBoard[]
  transfersTo        TransferLog[]       @relation("TransferTo")
  transfersFrom      TransferLog[]       @relation("TransferFrom")
}

model Coach {
  id             String   @id @default(cuid())
  name           String
  description    String?
  photo          String?
  phone          String?
  email          String?  @unique
  password       String?
  certifications String?
  visible        Boolean  @default(true)
  order          Int      @default(0)
  teamId         Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  team           Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
}

model Match {
  id            String       @id @default(cuid())
  category      String
  matchType     String       @default("turneu")
  round         String?
  date          DateTime
  location      String?
  homeTeam      String
  awayTeam      String
  homeScore     Int?
  awayScore     Int?
  isDinamo      Boolean      @default(true)
  notes         String?
  competitionId String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  competition   Competition? @relation(fields: [competitionId], references: [id])

  @@index([competitionId])
}

model TrainingSession {
  id        Int      @id @default(autoincrement())
  grupa     String
  day       String
  startTime String
  endTime   String
  location  String
  coachName String?
  createdAt DateTime @default(now())
}

model Banner {
  id          Int      @id @default(autoincrement())
  title       String
  image       String
  textOverlay String?
  subtitle    String?
  linkUrl     String?
  position    String   @default("header")
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SiteText {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model Video {
  id          Int               @id @default(autoincrement())
  title       String
  youtubeUrl  String
  description String?
  grupa       String?
  featured    Boolean           @default(false)
  createdAt   DateTime          @default(now())
  annotations VideoAnnotation[]
}

model Parent {
  id                String                    @id @default(cuid())
  name              String
  email             String                    @unique
  phone             String?
  password          String?
  token             String?
  tokenExpiry       DateTime?
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt
  children          Child[]
  conversations     ConversationParticipant[]
  sentMessages      Message[]
  payments          Payment[]
  pushSubscriptions PushSubscription[]
  requests          Request[]
}

model Child {
  id               String            @id @default(cuid())
  name             String
  birthYear        Int
  parentId         String
  teamId           Int?
  photoConsent     Boolean           @default(false)
  photoConsentWA   Boolean           @default(false)
  photoConsentDate DateTime?
  signatureData    String?
  medicalCert      Boolean           @default(false)
  publicProfile    Boolean           @default(false)
  publicBio        String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  badges           AthleteBadge[]
  attendances      Attendance[]
  team             Team?             @relation(fields: [teamId], references: [id])
  parent           Parent            @relation(fields: [parentId], references: [id], onDelete: Cascade)
  childPhotos      ChildPhoto[]
  evaluations      Evaluation[]
  fitnessData      FitnessData[]
  fitnessDevices   FitnessDevice[]
  medicalRecords   MedicalRecord[]
  payments         Payment[]
  physicalProfiles PhysicalProfile[]
  points           Points[]
  requests         Request[]
  transfers        TransferLog[]
}

model AccessRequest {
  id             String    @id @default(cuid())
  parentName     String
  email          String
  phone          String?
  childName      String
  childBirthYear Int
  teamId         Int?
  message        String?
  status         String    @default("pending")
  reviewedAt     DateTime?
  reviewedBy     String?
  createdAt      DateTime  @default(now())
  team           Team?     @relation(fields: [teamId], references: [id])
}

model PhysicalProfile {
  id        String   @id @default(cuid())
  childId   String
  date      DateTime @default(now())
  height    Float?
  weight    Float?
  position  String?
  notes     String?
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  child     Child    @relation(fields: [childId], references: [id], onDelete: Cascade)
}

model Evaluation {
  id        String   @id @default(cuid())
  childId   String
  date      DateTime @default(now())
  period    String
  physical  Int
  technical Int
  tactical  Int
  mental    Int
  social    Int
  comments  String?
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  child     Child    @relation(fields: [childId], references: [id], onDelete: Cascade)
}

model Attendance {
  id          String    @id @default(cuid())
  childId     String
  date        DateTime
  type        String    @default("antrenament")
  present     Boolean   @default(true)
  notes       String?
  teamId      Int?
  createdAt   DateTime  @default(now())
  checkinTime DateTime?
  sessionId   String?
  team        Team?     @relation(fields: [teamId], references: [id])
  child       Child     @relation(fields: [childId], references: [id], onDelete: Cascade)
}

model MedicalRecord {
  id          String    @id @default(cuid())
  childId     String
  date        DateTime  @default(now())
  type        String
  description String
  severity    String?
  returnDate  DateTime?
  resolved    Boolean   @default(false)
  createdBy   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  child       Child     @relation(fields: [childId], references: [id], onDelete: Cascade)
}

model ChildPhoto {
  id         String    @id @default(cuid())
  childId    String
  url        String
  caption    String?
  date       DateTime?
  event      String?
  uploadedBy String?
  createdAt  DateTime  @default(now())
  child      Child     @relation(fields: [childId], references: [id], onDelete: Cascade)
}

model RateLimit {
  id          Int      @id @default(autoincrement())
  key         String
  action      String
  count       Int      @default(1)
  windowStart DateTime @default(now())
  createdAt   DateTime @default(now())

  @@unique([key, action])
  @@index([action, windowStart])
}

model SiteSettings {
  id                    Int      @id @default(autoincrement())
  moduleHomepage        Boolean  @default(true)
  moduleEchipe          Boolean  @default(true)
  moduleProgram         Boolean  @default(true)
  moduleMeciuri         Boolean  @default(true)
  moduleGalerie         Boolean  @default(true)
  modulePovesti         Boolean  @default(true)
  moduleContact         Boolean  @default(true)
  moduleDespre          Boolean  @default(true)
  modulePortalParinti   Boolean  @default(true)
  moduleInscrieri       Boolean  @default(false)
  moduleCalendar        Boolean  @default(false)
  moduleNotificari      Boolean  @default(false)
  moduleStatistici      Boolean  @default(false)
  modulePlati           Boolean  @default(false)
  moduleMagazin         Boolean  @default(false)
  moduleVideoHighlights Boolean  @default(false)
  moduleSponsori        Boolean  @default(false)
  moduleFundraising     Boolean  @default(false)
  extraConfig           String   @default("{}")
  logo                  String?
  primaryColor          String   @default("#dc2626")
  secondaryColor        String   @default("#1e3a5f")
  accentColor           String   @default("#f59e0b")
  fontFamily            String   @default("Montserrat")
  heroTitle             String?
  heroSubtitle          String?
  clubName              String   @default("CS Dinamo București Rugby")
  clubAddress           String?
  clubPhone             String?
  clubEmail             String?
  favicon               String?
  ogImage               String?
  updatedAt             DateTime @updatedAt
}

model Campaign {
  id             String     @id @default(cuid())
  title          String
  description    String
  image          String?
  goalAmount     Float
  currentAmount  Float      @default(0)
  deadline       DateTime?
  active         Boolean    @default(true)
  showDonors     Boolean    @default(true)
  allowAnonymous Boolean    @default(true)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  donations      Donation[]
}

model Donation {
  id              String   @id @default(cuid())
  campaignId      String
  donorName       String?
  email           String?
  amount          Float
  anonymous       Boolean  @default(false)
  paymentMethod   String   @default("manual")
  stripeSessionId String?
  status          String   @default("completed")
  createdAt       DateTime @default(now())
  campaign        Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

model Payment {
  id              String   @id @default(cuid())
  parentId        String?
  childId         String?
  amount          Float
  type            String
  status          String   @default("pending")
  description     String?
  stripeSessionId String?
  receiptNumber   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  child           Child?   @relation(fields: [childId], references: [id])
  parent          Parent?  @relation(fields: [parentId], references: [id])
}

model Registration {
  id              String   @id @default(cuid())
  childFirstName  String
  childLastName   String
  birthDate       DateTime
  teamId          Int?
  parentName      String
  phone           String
  email           String
  experience      String?
  gdprConsent     Boolean  @default(true)
  status          String   @default("noua")
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  rejectionReason String?
  team            Team?    @relation(fields: [teamId], references: [id])
}

model CalendarEvent {
  id          String   @id @default(cuid())
  title       String
  type        String   @default("event")
  date        DateTime
  startTime   String?
  endTime     String?
  location    String?
  description String?
  teamId      Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  team        Team?    @relation(fields: [teamId], references: [id])
}

model Notification {
  id             String   @id @default(cuid())
  title          String
  body           String
  type           String   @default("general")
  recipientGroup String   @default("all")
  recipientCount Int      @default(0)
  sentAt         DateTime @default(now())
  sentBy         String?
  createdAt      DateTime @default(now())
}

model Product {
  id          String      @id @default(cuid())
  name        String
  description String?
  price       Float
  image       String?
  stock       Int         @default(0)
  category    String?
  active      Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  orderItems  OrderItem[]
}

model Sponsor {
  id          String   @id @default(cuid())
  name        String
  logo        String?
  website     String?
  description String?
  tier        String   @default("bronze")
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TransferLog {
  id         String   @id @default(cuid())
  childId    String
  fromTeamId Int
  toTeamId   Int
  reason     String?
  movedBy    String   @default("admin")
  createdAt  DateTime @default(now())
  toTeam     Team     @relation("TransferTo", fields: [toTeamId], references: [id])
  fromTeam   Team     @relation("TransferFrom", fields: [fromTeamId], references: [id])
  child      Child    @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@index([childId])
  @@index([createdAt])
}

model PushSubscription {
  id        String   @id @default(cuid())
  parentId  String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  parent    Parent   @relation(fields: [parentId], references: [id], onDelete: Cascade)

  @@index([parentId])
}

model Document {
  id          String   @id @default(cuid())
  title       String
  category    String   @default("general")
  filePath    String
  fileSize    Int      @default(0)
  mimeType    String   @default("application/pdf")
  targetGroup String   @default("all")
  teamId      Int?
  uploadedBy  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  team        Team?    @relation(fields: [teamId], references: [id])
}

model Order {
  id              String      @id @default(cuid())
  customerName    String
  email           String
  phone           String?
  total           Float
  status          String      @default("noua")
  stripeSessionId String?
  shippingAddress String?
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  items           OrderItem[]
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  name      String
  price     Float
  quantity  Int     @default(1)
  product   Product @relation(fields: [productId], references: [id])
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Competition {
  id          String            @id @default(cuid())
  name        String
  type        String            @default("turneu")
  season      String?
  category    String?
  startDate   DateTime?
  endDate     DateTime?
  description String?
  active      Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  teams       CompetitionTeam[]
  matches     Match[]
}

model CompetitionTeam {
  id            String      @id @default(cuid())
  competitionId String
  teamName      String
  points        Int         @default(0)
  played        Int         @default(0)
  won           Int         @default(0)
  drawn         Int         @default(0)
  lost          Int         @default(0)
  goalsFor      Int         @default(0)
  goalsAgainst  Int         @default(0)
  competition   Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)

  @@index([competitionId])
}

model Conversation {
  id           String                    @id @default(cuid())
  type         String                    @default("direct")
  subject      String?
  teamId       Int?
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
  team         Team?                     @relation(fields: [teamId], references: [id])
  participants ConversationParticipant[]
  messages     Message[]
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  conversationId String
  parentId       String?
  userId         Int?
  lastReadAt     DateTime?
  createdAt      DateTime     @default(now())
  user           User?        @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent         Parent?      @relation(fields: [parentId], references: [id], onDelete: Cascade)
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([conversationId, parentId])
  @@unique([conversationId, userId])
  @@index([parentId])
  @@index([userId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderParentId String?
  senderUserId   Int?
  content        String
  attachmentUrl  String?
  createdAt      DateTime     @default(now())
  senderUser     User?        @relation(fields: [senderUserId], references: [id])
  senderParent   Parent?      @relation(fields: [senderParentId], references: [id])
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model AttendanceSession {
  id        String   @id @default(cuid())
  teamId    Int
  date      DateTime @default(now())
  qrToken   String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
  @@index([qrToken])
}

model Request {
  id          String    @id @default(cuid())
  parentId    String
  childId     String?
  type        String    @default("absenta")
  title       String
  description String?
  status      String    @default("pending")
  response    String?
  reviewedBy  String?
  reviewedAt  DateTime?
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  child       Child?    @relation(fields: [childId], references: [id])
  parent      Parent    @relation(fields: [parentId], references: [id], onDelete: Cascade)

  @@index([parentId])
  @@index([status])
}

model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  label       String
  permissions String   @default("{}")
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]
}

model ApiKey {
  id                 String    @id @default(cuid())
  name               String
  key                String    @unique
  permissions        String    @default("[]")
  rateLimitPerMinute Int       @default(60)
  lastUsedAt         DateTime?
  createdBy          String?
  active             Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([key])
}

model VideoAnnotation {
  id        String   @id @default(cuid())
  videoId   Int
  timestamp Float
  text      String
  author    String?
  createdAt DateTime @default(now())
  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@index([videoId])
}

model TacticalBoard {
  id        String   @id @default(cuid())
  name      String
  formation String   @default("{}")
  notes     String?
  teamId    Int?
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  team      Team?    @relation(fields: [teamId], references: [id])
}

model Badge {
  id          String         @id @default(cuid())
  name        String
  icon        String         @default("🏅")
  description String?
  criteria    String         @default("{}")
  category    String         @default("general")
  active      Boolean        @default(true)
  createdAt   DateTime       @default(now())
  athletes    AthleteBadge[]
}

model AthleteBadge {
  id       String   @id @default(cuid())
  childId  String
  badgeId  String
  earnedAt DateTime @default(now())
  badge    Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  child    Child    @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@unique([childId, badgeId])
  @@index([childId])
}

model Points {
  id        String   @id @default(cuid())
  childId   String
  amount    Int
  reason    String
  createdAt DateTime @default(now())
  child     Child    @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@index([childId])
}

model FitnessDevice {
  id           String   @id @default(cuid())
  childId      String
  provider     String
  accessToken  String?
  refreshToken String?
  connected    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  child        Child    @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@index([childId])
}

model FitnessData {
  id           String   @id @default(cuid())
  childId      String
  date         DateTime
  heartRateAvg Int?
  heartRateMax Int?
  distance     Float?
  sprintCount  Int?
  calories     Int?
  sleepHours   Float?
  source       String   @default("manual")
  notes        String?
  createdAt    DateTime @default(now())
  child        Child    @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@index([childId, date])
}

model ScoutingReport {
  id        String     @id @default(cuid())
  scoutId   String?
  eventName String
  eventDate DateTime
  location  String?
  notes     String?
  createdBy String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  prospects Prospect[]
}

model Prospect {
  id               String          @id @default(cuid())
  name             String
  birthYear        Int?
  position         String?
  currentClub      String?
  notes            String?
  rating           Int             @default(0)
  status           String          @default("identified")
  phone            String?
  email            String?
  scoutingReportId String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  scoutingReport   ScoutingReport? @relation(fields: [scoutingReportId], references: [id])

  @@index([status])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    Int?
  username  String?
  action    String
  entity    String
  entityId  String?
  details   String?
  ip        String?
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
}
