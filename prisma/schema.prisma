generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  name      String
  role      String   @default("editor")
  createdAt DateTime @default(now())
}

model Story {
  id         Int      @id @default(autoincrement())
  title      String
  slug       String   @unique
  content    String
  excerpt    String?
  coverImage String?
  videoUrl   String?
  grupa      String?
  category   String?
  status     String   @default("published")
  published  Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  photos     Photo[]
}

model Photo {
  id        Int      @id @default(autoincrement())
  filename  String
  path      String
  caption   String?
  grupa     String?
  albumName String?
  storyId   Int?
  story     Story?   @relation(fields: [storyId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
}

model Team {
  id          Int      @id @default(autoincrement())
  grupa       String   @unique
  coachName   String   // deprecated — use Coach model
  coachPhoto  String?  // deprecated — use Coach model
  coachBio    String?  // deprecated — use Coach model
  schedule    String?
  description String?
  active      Boolean  @default(true)
  color       String   @default("green")
  sortOrder   Int      @default(0)
  ageRange    String?
  birthYear   String?
  updatedAt       DateTime        @updatedAt
  coaches         Coach[]
  children        Child[]
  accessRequests  AccessRequest[]
  attendances     Attendance[]
  registrations   Registration[]
  calendarEvents  CalendarEvent[]
}

model Coach {
  id          String   @id @default(cuid())
  name        String
  description String?
  photo       String?
  order       Int      @default(0)
  teamId      Int
  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Match {
  id        String   @id @default(cuid())
  category  String   // U10, U12, U14
  matchType String   @default("turneu") // "turneu" or "meci"
  round     String?  // "Etapa 1", "Festival Mini Rugby" etc.
  date      DateTime
  location  String?
  homeTeam  String
  awayTeam  String
  homeScore Int?     // null = not played yet
  awayScore Int?
  isDinamo  Boolean  @default(true)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TrainingSession {
  id        Int      @id @default(autoincrement())
  grupa     String
  day       String
  startTime String
  endTime   String
  location  String
  coachName String?
  createdAt DateTime @default(now())
}

model Banner {
  id          Int      @id @default(autoincrement())
  title       String
  image       String
  textOverlay String?
  subtitle    String?
  linkUrl     String?
  position    String   @default("header")
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SiteText {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model Video {
  id          Int      @id @default(autoincrement())
  title       String
  youtubeUrl  String
  description String?
  grupa       String?
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model Parent {
  id          String    @id @default(cuid())
  name        String
  email       String    @unique
  phone       String?
  token       String?
  tokenExpiry DateTime?
  children    Child[]
  payments    Payment[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Child {
  id               String    @id @default(cuid())
  name             String
  birthYear        Int
  parentId         String
  parent           Parent    @relation(fields: [parentId], references: [id], onDelete: Cascade)
  teamId           Int?
  team             Team?     @relation(fields: [teamId], references: [id], onDelete: SetNull)
  photoConsent     Boolean   @default(false)
  photoConsentWA   Boolean   @default(false)
  photoConsentDate DateTime?
  signatureData    String?
  medicalCert      Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  physicalProfiles PhysicalProfile[]
  evaluations      Evaluation[]
  attendances      Attendance[]
  medicalRecords   MedicalRecord[]
  childPhotos      ChildPhoto[]
  payments         Payment[]
}

model AccessRequest {
  id             String    @id @default(cuid())
  parentName     String
  email          String
  phone          String?
  childName      String
  childBirthYear Int
  teamId         Int?
  team           Team?     @relation(fields: [teamId], references: [id])
  message        String?
  status         String    @default("pending")
  reviewedAt     DateTime?
  reviewedBy     String?
  createdAt      DateTime  @default(now())
}

model PhysicalProfile {
  id        String   @id @default(cuid())
  childId   String
  child     Child    @relation(fields: [childId], references: [id], onDelete: Cascade)
  date      DateTime @default(now())
  height    Float?
  weight    Float?
  position  String?
  notes     String?
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Evaluation {
  id        String   @id @default(cuid())
  childId   String
  child     Child    @relation(fields: [childId], references: [id], onDelete: Cascade)
  date      DateTime @default(now())
  period    String
  physical  Int
  technical Int
  tactical  Int
  mental    Int
  social    Int
  comments  String?
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Attendance {
  id        String   @id @default(cuid())
  childId   String
  child     Child    @relation(fields: [childId], references: [id], onDelete: Cascade)
  date      DateTime
  type      String   @default("antrenament")
  present   Boolean  @default(true)
  notes     String?
  teamId    Int?
  team      Team?    @relation(fields: [teamId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
}

model MedicalRecord {
  id          String    @id @default(cuid())
  childId     String
  child       Child     @relation(fields: [childId], references: [id], onDelete: Cascade)
  date        DateTime  @default(now())
  type        String
  description String
  severity    String?
  returnDate  DateTime?
  resolved    Boolean   @default(false)
  createdBy   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model ChildPhoto {
  id         String    @id @default(cuid())
  childId    String
  child      Child     @relation(fields: [childId], references: [id], onDelete: Cascade)
  url        String
  caption    String?
  date       DateTime?
  event      String?
  uploadedBy String?
  createdAt  DateTime  @default(now())
}

model RateLimit {
  id        Int      @id @default(autoincrement())
  key       String
  action    String
  count     Int      @default(1)
  windowStart DateTime @default(now())
  createdAt DateTime @default(now())

  @@unique([key, action])
  @@index([action, windowStart])
}

model SiteSettings {
  id                    Int      @id @default(1)
  moduleHomepage        Boolean  @default(true)
  moduleEchipe          Boolean  @default(true)
  moduleProgram         Boolean  @default(true)
  moduleMeciuri         Boolean  @default(true)
  moduleGalerie         Boolean  @default(true)
  modulePovesti         Boolean  @default(true)
  moduleContact         Boolean  @default(true)
  moduleDespre          Boolean  @default(true)
  modulePortalParinti   Boolean  @default(true)
  moduleInscrieri       Boolean  @default(false)
  moduleCalendar        Boolean  @default(false)
  moduleNotificari      Boolean  @default(false)
  moduleStatistici      Boolean  @default(false)
  modulePlati           Boolean  @default(false)
  moduleMagazin         Boolean  @default(false)
  moduleVideoHighlights Boolean  @default(false)
  moduleSponsori        Boolean  @default(false)
  moduleFundraising     Boolean  @default(false)
  extraConfig           String   @default("{}")
  updatedAt             DateTime @updatedAt
}

model Campaign {
  id             String     @id @default(cuid())
  title          String
  description    String
  image          String?
  goalAmount     Float
  currentAmount  Float      @default(0)
  deadline       DateTime?
  active         Boolean    @default(true)
  showDonors     Boolean    @default(true)
  allowAnonymous Boolean    @default(true)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  donations      Donation[]
}

model Donation {
  id              String   @id @default(cuid())
  campaignId      String
  campaign        Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  donorName       String?
  email           String?
  amount          Float
  anonymous       Boolean  @default(false)
  paymentMethod   String   @default("manual")
  stripeSessionId String?
  status          String   @default("completed")
  createdAt       DateTime @default(now())
}

model Payment {
  id              String   @id @default(cuid())
  parentId        String?
  parent          Parent?  @relation(fields: [parentId], references: [id], onDelete: SetNull)
  childId         String?
  child           Child?   @relation(fields: [childId], references: [id], onDelete: SetNull)
  amount          Float
  type            String
  status          String   @default("pending")
  description     String?
  stripeSessionId String?
  receiptNumber   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Registration {
  id             String   @id @default(cuid())
  childFirstName String
  childLastName  String
  birthDate      DateTime
  teamId         Int?
  team           Team?    @relation(fields: [teamId], references: [id], onDelete: SetNull)
  parentName     String
  phone          String
  email          String
  experience     String?
  gdprConsent    Boolean  @default(true)
  status          String   @default("noua")
  notes           String?
  rejectionReason String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model CalendarEvent {
  id          String   @id @default(cuid())
  title       String
  type        String   @default("event")
  date        DateTime
  startTime   String?
  endTime     String?
  location    String?
  description String?
  teamId      Int?
  team        Team?    @relation(fields: [teamId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Notification {
  id             String   @id @default(cuid())
  title          String
  body           String
  type           String   @default("general")
  recipientGroup String   @default("all")
  recipientCount Int      @default(0)
  sentAt         DateTime @default(now())
  sentBy         String?
  createdAt      DateTime @default(now())
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Float
  image       String?
  stock       Int      @default(0)
  category    String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Sponsor {
  id          String   @id @default(cuid())
  name        String
  logo        String?
  website     String?
  description String?
  tier        String   @default("bronze")
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
